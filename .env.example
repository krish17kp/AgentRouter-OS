# AgentRouter OS — environment variables
# MVP needs NO secrets: adapters run catalog-only (planner, not executor).

# Override the data/config home (default: ~/.agentrouter)
# AGENTROUTER_HOME=

# --- Capstone tier and later (providers refresh / execution) — unused in MVP ---
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=your_openrouter_api_key_here